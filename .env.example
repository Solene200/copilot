INCIDENT_COPILOT_ENVIRONMENT=development
INCIDENT_COPILOT_DEBUG=false
INCIDENT_COPILOT_LOG_LEVEL=INFO
INCIDENT_COPILOT_API_PREFIX=/api
INCIDENT_COPILOT_SSE_HEARTBEAT_SECONDS=15
INCIDENT_COPILOT_CHECKPOINT_BACKEND=memory
# Use `prometheus` only when the local observability stack is running.
INCIDENT_COPILOT_METRICS_BACKEND=fixture
INCIDENT_COPILOT_PROMETHEUS_BASE_URL=http://127.0.0.1:9090
INCIDENT_COPILOT_PROMETHEUS_TIMEOUT_SECONDS=2
# Optional production target. Install with `uv sync --extra postgres` first.
# INCIDENT_COPILOT_POSTGRES_DSN=postgresql://user:password@localhost:5432/incident_copilot
# Optional. The application and test suite do not require a model API key.
INCIDENT_COPILOT_MODEL_API_KEY=
